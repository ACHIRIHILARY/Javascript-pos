# PostgreSQL connection string for runtime queries
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?schema=public

# Optional direct connection URL for migrations and seeding
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Authentication
JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
JWT_EXPIRY=8h

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173
